{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "lib": ["ES2025", "ESNext.Array", "ESNext.Error"],
    "types": ["vitest/globals", "node"],
    "jsx": "react-jsx",
    "composite": true,
    "noEmit": true
  },
  "files": ["package.json"],
  "include": ["**/*.test.*", "**/*.spec.*", "types/**/*.d.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
