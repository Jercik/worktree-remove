{
  "name": "worktree-remove",
  "version": "1.0.0",
  "description": "Safely remove Git worktrees and their directories, handling uncommitted changes and orphaned folders.",
  "keywords": [
    "branch",
    "cleanup",
    "cli",
    "delete",
    "git",
    "git-worktree",
    "remove",
    "safe-delete",
    "trash",
    "workflow",
    "worktree"
  ],
  "homepage": "https://github.com/Jercik/worktree-remove#readme",
  "bugs": {
    "url": "https://github.com/Jercik/worktree-remove/issues"
  },
  "license": "MIT",
  "author": "Łukasz Jerciński",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jercik/worktree-remove.git"
  },
  "bin": {
    "worktree-remove": "bin/worktree-remove"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.app.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "format": "oxfmt --config .oxfmtrc.json .",
    "format:check": "oxfmt --check --config .oxfmtrc.json .",
    "fta": "fta-check --threshold 55",
    "knip": "knip",
    "lint": "oxlint --deny-warnings --report-unused-disable-directives .",
    "prepack": "pnpm run rebuild",
    "prepare": "git config core.hooksPath .githooks",
    "rebuild": "pnpm run clean && pnpm run build",
    "start": "pnpm run rebuild && node bin/worktree-remove",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsgo -b --noEmit"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@inquirer/prompts": "^8.4.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "p-limit": "^7.3.0",
    "trash": "^10.1.1"
  },
  "devDependencies": {
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "beta",
    "@vitest/coverage-v8": "^4.1.5",
    "fta-check": "^1.5.2",
    "fta-cli": "^3.0.0",
    "knip": "^6.6.3",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-config-j4k": "2.3.0",
    "oxlint-tsgolint": "^0.22.0",
    "semantic-release": "^25.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
